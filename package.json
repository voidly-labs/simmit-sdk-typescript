{
  "name": "@simmit/sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for the Simmit API — cloud execution for SimulationCraft",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "generate": "bash scripts/generate.sh",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:package": "publint && attw --pack ."
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/node": "^20.19.43",
    "openapi-typescript": "^7.4.0",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "simmit",
    "simulationcraft",
    "simc",
    "wow",
    "sdk",
    "api-client"
  ],
  "author": "Voidly Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voidly-labs/simmit-sdk-typescript.git"
  },
  "homepage": "https://github.com/voidly-labs/simmit-sdk-typescript",
  "bugs": {
    "url": "https://github.com/voidly-labs/simmit-sdk-typescript/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
